---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-author">
					<img
						src="/jeff-huang.png"
						alt="Jeff Huang"
						class="hero-photo"
						width="80"
						height="80"
						loading="eager"
					/>
					<div>
						<p class="hero-name">Jeff Huang</p>
						<p class="hero-role">
							Google · <a href="https://genkit.dev/">Genkit</a> · ex-Uber
						</p>
					</div>
				</div>
				<h1>A journal on building agents,<br />written as I go.</h1>
				<p class="page-lead">
					Field notes on production patterns, infrastructure, and whatever I'm working
					through that week. Some posts dig into one project; others are shorter notes.
				</p>
				<p class="page-lead page-lead-muted page-lead-last">
					Five years on Firebase Functions and Extensions making serverless feel simple.
					Agents are the same job. I observe and distill what I learn while building
					<a href="https://genkit.dev/">Genkit</a>.
				</p>
			</section>

			<section class="recent">
				<div class="section-head">
					<h2>Recent</h2>
					<a href="/blog/" class="view-all">All writing →</a>
				</div>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-meta">
										<FormattedDate date={post.data.pubDate} />
									</p>
									{post.data.description && (
										<p class="post-desc">{post.data.description}</p>
									)}
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		margin-bottom: 3.5rem;
		max-width: var(--measure);
	}

	.hero-author {
		display: flex;
		align-items: center;
		gap: 1rem;
		margin-bottom: 1.5rem;
	}

	.hero-photo {
		width: 80px;
		height: 80px;
		border-radius: 50%;
		object-fit: cover;
		border: 1px solid var(--border);
	}

	.hero-name {
		font-family: var(--font-serif);
		font-size: 1.125rem;
		font-weight: 500;
		margin: 0 0 0.15rem;
		letter-spacing: -0.01em;
	}

	.hero-role {
		font-size: 0.8125rem;
		color: var(--text-muted);
		margin: 0;
	}

	.hero-role a {
		color: var(--text-muted);
		text-decoration: none;
	}

	.hero-role a:hover {
		color: var(--text);
	}

	.hero h1 {
		margin-bottom: 1.25rem;
	}

	.page-lead + .page-lead {
		margin-top: 0.75rem;
	}

	.page-lead-muted {
		color: var(--text-muted);
		font-size: 0.9375rem;
	}

	.page-lead-muted a {
		color: var(--text-muted);
		text-decoration: underline;
		text-underline-offset: 0.12em;
	}

	.page-lead-muted a:hover {
		color: var(--text);
	}

	.recent {
		max-width: var(--measure-wide);
	}

	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 0.5rem;
	}

	.section-head h2 {
		font-size: 0.75rem;
		font-family: var(--font-sans);
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-faint);
		margin: 0;
	}

	.view-all {
		font-size: 0.8125rem;
		color: var(--text-muted);
		text-decoration: none;
	}

	.view-all:hover {
		color: var(--text);
	}
</style>
