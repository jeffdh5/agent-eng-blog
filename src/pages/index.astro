---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="page-eyebrow">Harness engineering notes</p>
				<h1>What coding agent harnesses<br />actually do, with receipts.</h1>
				<p class="page-lead">
					If you're building a coding agent for your team, most of the hard problems
					aren't the model. They're the harness: the tool loop that keeps a growing
					message history, the context that fills up with file bodies, the guards that
					stop the agent from quitting early or retrying the same failure forever.
				</p>
				<p class="page-lead">
					Teams at Stripe, Ramp, and Coinbase built internal agents independently and
					converged on the same shape. <a href="https://github.com/langchain-ai/open-swe">Open SWE</a>
					and <a href="https://github.com/langchain-ai/deepagents">Deep Agents</a> are the
					most legible open-source versions of that shape. They're reference
					implementations, not the stack everyone ships, but they're the best public
					autopsy of what production-shaped harnesses look like. I read them, measure
					the failure modes, and implement the patterns with
					<a href="https://genkit.dev">Genkit</a>.
				</p>
				<p class="page-lead page-lead-last">
					I spent years on Firebase serverless making hard infrastructure feel simple;
					agent harnesses are the same job again, at the very beginning of figuring out
					what's possible, and I'm writing this while we build the open-source
					primitives and watch the patterns emerge.
				</p>
			</section>

			<section class="recent">
				<div class="section-head">
					<h2>Recent</h2>
					<a href="/blog/" class="view-all">All writing →</a>
				</div>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-meta">
										<FormattedDate date={post.data.pubDate} />
									</p>
									{post.data.description && (
										<p class="post-desc">{post.data.description}</p>
									)}
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		margin-bottom: 3.5rem;
		max-width: var(--measure);
	}

	.hero h1 {
		margin-bottom: 1.25rem;
	}

	.page-lead + .page-lead {
		margin-top: 1rem;
	}

	.page-lead-last {
		color: var(--text-muted);
		font-size: 0.9375rem;
	}

	.recent {
		max-width: var(--measure-wide);
	}

	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 0.5rem;
	}

	.section-head h2 {
		font-size: 0.75rem;
		font-family: var(--font-sans);
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-faint);
		margin: 0;
	}

	.view-all {
		font-size: 0.8125rem;
		color: var(--text-muted);
		text-decoration: none;
	}

	.view-all:hover {
		color: var(--text);
	}
</style>
