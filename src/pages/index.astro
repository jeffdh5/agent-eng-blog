---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="page-eyebrow">Agent infrastructure notes</p>
				<h1>Agents are having their<br />serverless moment.</h1>
				<p class="page-lead">
					I'm Jeff Huang — founding team of <a href="https://genkit.dev">Genkit</a>,
					where I lead the Python SDK. Before that I spent years building Firebase's
					serverless platform. My job is deciding which parts of an agent harness become
					platform — so I read the open-source ones the way other people read papers:
					Claude Code, Goose, Open SWE, the internal agents companies describe on their
					eng blogs. Here I distill what they converge on into best practices, then show
					how to build each one with Genkit. Same playbook as serverless, one layer up.
				</p>
			</section>

			<section class="recent">
				<div class="section-head">
					<h2>Recent</h2>
					<a href="/blog/" class="view-all">All writing →</a>
				</div>
				<ul class="post-list">
					{
						posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									<h3 class="post-title">{post.data.title}</h3>
									<p class="post-meta">
										<FormattedDate date={post.data.pubDate} />
									</p>
									{post.data.description && (
										<p class="post-desc">{post.data.description}</p>
									)}
								</a>
							</li>
						))
					}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		margin-bottom: 3.5rem;
		max-width: var(--measure);
	}

	.hero h1 {
		margin-bottom: 1.25rem;
	}

	.recent {
		max-width: var(--measure-wide);
	}

	.section-head {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 0.5rem;
	}

	.section-head h2 {
		font-size: 0.75rem;
		font-family: var(--font-sans);
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--text-faint);
		margin: 0;
	}

	.view-all {
		font-size: 0.8125rem;
		color: var(--text-muted);
		text-decoration: none;
	}

	.view-all:hover {
		color: var(--text);
	}
</style>
