---
const year = new Date().getFullYear();
---

<footer>
	<p>
		<span>{year} Jeff Huang</span>
		<span class="sep">·</span>
		<span>Genkit · Google (Firebase) · Uber</span>
		<span class="sep">·</span>
		<a href="https://github.com/jeffdh5/agent-eng-blog">source</a>
	</p>
</footer>

<style>
	footer {
		border-top: 1px solid var(--border);
		padding: 2rem 0 3rem;
		margin-top: 1rem;
	}

	p {
		width: var(--measure-wide);
		max-width: calc(100% - 2.5rem);
		margin: 0 auto;
		font-size: 0.8125rem;
		color: var(--text-faint);
	}

	.sep {
		margin: 0 0.5rem;
	}

	a {
		color: var(--text-faint);
		text-decoration: none;
	}

	a:hover {
		color: var(--text-muted);
	}

	@media (max-width: 640px) {
		p {
			max-width: calc(100% - 1.5rem);
		}
	}
</style>
